{
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/ms-arch run build",
  "outputDirectory": "artifacts/ms-arch/dist/public",
  "installCommand": "npm install -g pnpm && pnpm install --frozen-lockfile=false",
  "framework": null,
  "rewrites": [
    { "source": "/api/run-agent", "destination": "/api/run-agent" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
